{
  "name": "@money-manager/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --max-warnings 0",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs",
    "db:generate": "pnpm run build && drizzle-kit generate --schema ./dist/schema/index.js --dialect postgresql --out ./migrations",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:runtime": "node ./scripts/run-migrations.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.3",
    "pg": "^8.14.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/pg": "^8.11.11",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2"
  }
}
