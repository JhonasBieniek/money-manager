# PostgreSQL
DATABASE_URL=postgresql://money_manager:money_manager@localhost:5432/money_manager

# API (apps/api)
# Imagem Docker: antes de subir o Fastify, aplica migrations em packages/db se RUN_DB_MIGRATIONS=true (padrão).
# Com várias réplicas da API, use false aqui (ou no Coolify) e rode migrations uma vez (job / pre-deploy).
RUN_DB_MIGRATIONS=true
API_HOST=0.0.0.0
API_PORT=3001
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
INTERNAL_API_KEY=change-me-internal-bot-key

# Web (apps/web) — use public URLs in production (Coolify / Traefik)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Bot (apps/bot)
# Dev local: TELEGRAM_USE_POLLING=true + stack local (API + Postgres). Ideal usar token de um bot só de dev (@BotFather);
# não use o token de produção com polling se deleteWebhook quebrar o webhook da Coolify.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USE_POLLING=false
BOT_PORT=3002
API_INTERNAL_URL=http://localhost:3001
OCR_SERVICE_URL=http://localhost:8000

# OCR (apps/ocr)
OCR_HOST=0.0.0.0
OCR_PORT=8000
OCR_LANGUAGES=pt,en
