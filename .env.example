# money-manager - Environment variables
#
# Copie este arquivo para `.env` e preencha com os valores reais.
# Nao commitie secrets.
#

# --------------------------------------------
# Node / Runtime
# --------------------------------------------
NODE_ENV=development
# sqlite → migrations em packages/db/migrations/sqlite (SQLITE_PATH)
# supabase → migrations em packages/db/migrations/postgres (DATABASE_URL)
# Aplicar: pnpm db:migrate (na raiz do monorepo)
DB_PROVIDER=sqlite
SQLITE_PATH=./data/money-manager.sqlite

# --------------------------------------------
# API (apps/api)
# --------------------------------------------
API_HOST=0.0.0.0
API_PORT=3001

# Usado para autenticar requests internas (ex: bot -> API)
INTERNAL_API_KEY=dev-internal

# Banco (obrigatorio)
# Se estiver usando docker-compose, via conexao do host, normalmente e:
#  - localhost:15432 (porta publicada do Postgres)
DATABASE_URL=postgresql://money_manager:money_manager@localhost:15432/money_manager

# Controla se o entrypoint da API roda migrations runtime
RUN_DB_MIGRATIONS=true

# --------------------------------------------
# Web (apps/web)
# --------------------------------------------
# Base URL usada pelo frontend para chamar a API
NEXT_PUBLIC_API_URL=http://localhost:3001

# --------------------------------------------
# Bot (apps/bot)
# --------------------------------------------
TELEGRAM_BOT_TOKEN=
# Segredo compartilhado para vincular seu chat ao app (envie /start <codigo> no bot).
# Deve ser o mesmo valor na API e no Telegram; escolha uma string longa e aleatoria.
TELEGRAM_LINK_CODE=change-me-telegram-link-code
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USE_POLLING=false
BOT_PORT=3002

# Base URL interna (quando o bot chama a API)
API_INTERNAL_URL=http://localhost:3001

# Servico de OCR (apps/ocr)
OCR_SERVICE_URL=http://localhost:8000

# Servico de STT (apps/stt)
STT_SERVICE_URL=http://localhost:8001

# --------------------------------------------
# OCR (apps/ocr)
# --------------------------------------------
OCR_LANGUAGES=pt,en
OCR_HOST=0.0.0.0
OCR_PORT=8000
# Interpretador para criar apps/ocr/.venv (ex.: python3.12 se o python3 padrao for 3.14+)
# OCR_PYTHON=python3.12

# --------------------------------------------
# STT (apps/stt)
# --------------------------------------------
STT_HOST=0.0.0.0
STT_PORT=8001
STT_MODEL=small
STT_LANGUAGE=pt
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_NOISE_REDUCTION=false
# Interpretador para criar apps/stt/.venv
# STT_PYTHON=python3.12

# --------------------------------------------
# docker-compose (quando aplicavel)
# --------------------------------------------
POSTGRES_PASSWORD=money_manager
POSTGRES_PUBLISH_PORT=15432
