{
  "name": "money-manager",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');const {spawnSync}=require('child_process');if(fs.existsSync('packages/types/tsconfig.build.json')){const r=spawnSync('pnpm',['--filter','@money-manager/types','run','build'],{stdio:'inherit',shell:true});process.exit(r.status??1);}\"",
    "setup": "node ./scripts/setup.mjs",
    "db:migrate": "pnpm --filter @money-manager/db run db:migrate",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:bot": "pnpm --filter @money-manager/bot run dev",
    "dev:ocr": "node scripts/dev-ocr.mjs",
    "dev:stt": "node scripts/dev-stt.mjs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.25.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
